# Features selected from lasso path analysis (siena06 dataset)
EST_FEATURES=delta_instructions,delta_cache_misses,delta_branch_instructions,delta_io_bytes,syscall_class_network,syscall_class_memory,syscall_class_other

# Regularization
EST_L1_PENALTY=0.1
EST_STATIC_PENALTY=0.0

# Static baseline model: "scalar" (default) or "weighted"
EST_STATIC_MODEL=scalar

# Extra features for Z in weighted mode (comma-separated, empty = just baseline+n_processes)
EST_STATIC_FEATURES=
